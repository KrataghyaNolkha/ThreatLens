# NVD API Key (National Vulnerability Database)
# Free service: Sign up at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# VirusTotal API Key
# Free service: Create an account at https://www.virustotal.com/ and get your key under profile -> API Key
VT_API_KEY=your_virustotal_api_key_here

# Groq API Key (For LLM / SOC Report Generation)
# Free service: Sign up at https://console.groq.com/keys for fast LLaMA models
GROQ_API_KEY=your_groq_api_key_here

# OpenCage API Key (For Geolocation Enrichment)
# Free service: Sign up at https://opencagedata.com/ (Free tier gives 2,500 requests/day)
OPENCAGE_API_KEY=your_opencage_api_key_here

# IPInfo Token (For IP Geolocation Backup)
# Free service: Sign up at https://ipinfo.io/ (Free tier gives 50,000 requests/month)
IPINFO_TOKEN=your_ipinfo_token_here

# MySQL Database Configuration (Optional - Defaults to SQLite)
DB_BACKEND=sqlite
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=threatlens

# SMTP Email Configuration (for SOAR Email Alerts)
# For Gmail: use an App Password (not your real password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address_here
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=your_sender_email_here

# JWT Authentication
# IMPORTANT: Change JWT_SECRET to a long random string in production!
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAYS=7
